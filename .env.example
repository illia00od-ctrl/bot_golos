# Обов'язково для роботи бота
BOT_TOKEN=

# ID робочої групи (негативне число): єдиний канал доставки заявок.
TARGET_CHAT_ID=

# Підказка: скинути очікування/діалог — у боті команди /finish (клієнт або адмін)

# Опційно — SMTP (функція send_email у коді наразі не підключена до сценаріїв бота)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
