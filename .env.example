# Обов'язково для роботи бота
BOT_TOKEN=

# Telegram user id адміністраторів через кому (кожен має натиснути /start у бота)
# Приклад: ADMIN_USER_IDS=123456789,987654321
# Достатньо хоча б одного з двох: ADMIN_USER_IDS або TARGET_CHAT_ID (група)
ADMIN_USER_IDS=

# ID робочої групи (негативне число): копія заявки для перегляду (без кнопок, без пересилання відповідей з групи).
# Можна комбінувати з ADMIN_USER_IDS — тоді в групі лише інформування, керування — у приваті з ботом.
TARGET_CHAT_ID=

# Підказка: скинути очікування/діалог — у боті команди /finish (клієнт або адмін)

# Опційно — SMTP (функція send_email у коді наразі не підключена до сценаріїв бота)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
